{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Skynet",
  "version": "1.0.0",
  "identifier": "com.private-rag.desktop",
  "build": {
    "frontendDist": "../src/renderer/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Skynet",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "public.app-category.productivity",
    "targets": ["dmg", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
