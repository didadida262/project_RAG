# 全部走本地文件，不从网络拉嵌入权重（勿再写 EMBEDDING_MODEL_NAME 指向 Hub，否则会偷偷下载）。
# 嵌入目录为 git clone 时：若加载失败，到该目录执行 git lfs pull 拉全权重。
# 若推理报错 No module named 'llama_cpp'：在 backend 运行 install-llm-windows-cpu.bat（勿用会触发 CMake 的裸 pip）

# --- 对话 GGUF ---
# macOS：# GGUF_MODEL_PATH=~/models/all_models/gemma-4-E4B-it-Q6_K.gguf
# GGUF_MODEL_PATH=F:/models/all_models/gemma-4-E4B-it-Q6_K.gguf
GGUF_MODEL_PATH=/Users/miles_wang/Desktop/work/models/all_models/gemma-4-E4B-it-Q6_K.gguf

# Optional: how many layers to offload to GPU (4060 8GB: try 20–35 with Q4)
N_GPU_LAYERS=0

MAX_CONTEXT_CHARS=8000
MAX_NEW_TOKENS=512
N_CTX=4096
RAG_TOP_K=12

# 分块（入库脚本与 API 共用）
# CHUNK_MAX_CHARS=1200
# CHUNK_OVERLAP=120

# --- 嵌入：仅本地目录（与 sentence-transformers 仓库 clone 路径一致）---
# macOS：# EMBEDDING_MODEL_PATH=~/models/all-MiniLM-L6-v2
# EMBEDDING_MODEL_PATH=F:/models/all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH = /Users/miles_wang/Desktop/work/models/all-MiniLM-L6-v2

# 镜像（仅当你仍需要从 Hub 拉别的资源时再开；本地嵌入一般不必）
# HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DOWNLOAD_TIMEOUT=300
