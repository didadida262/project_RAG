# Path to Gemma (or other) GGUF file — required for real answers
GGUF_MODEL_PATH=

# Optional: how many layers to offload to GPU (4060 8GB: try 20–35 with Q4)
N_GPU_LAYERS=0

# Context window budget for retrieved text (chars) before LLM
MAX_CONTEXT_CHARS=6000

# Generation
MAX_NEW_TOKENS=512
N_CTX=4096

# Retrieval
RAG_TOP_K=5
