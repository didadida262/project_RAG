# Path to Gemma (or other) GGUF file — required for real answers
GGUF_MODEL_PATH=

# Optional: comma-separated list of .gguf paths for the UI model dropdown (defaults to GGUF_MODEL_PATH only)
# GGUF_MODEL_PATHS=/models/a.Q4_K_M.gguf,/models/b.Q8_0.gguf

# Optional: how many layers to offload to GPU (4060 8GB: try 20–35 with Q4)
N_GPU_LAYERS=0

# Context window budget for retrieved text (chars) before LLM
MAX_CONTEXT_CHARS=8000

# Generation
MAX_NEW_TOKENS=512
N_CTX=4096

# Retrieval（中文建议 ≥10）
RAG_TOP_K=12

# 分块（入库脚本与 API 共用）
# CHUNK_MAX_CHARS=1200
# CHUNK_OVERLAP=120

# --- 向量嵌入 ---
# 中文语料不要用纯英文 all-MiniLM-L6-v2，检索质量差；推荐：
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# 换嵌入模型后必须 ./ingest_docs.sh --clear 再导入。
# EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#
# 镜像（需要时取消注释）
# HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DOWNLOAD_TIMEOUT=300

# 本地快照目录（与 EMBEDDING_MODEL_NAME 二选一，路径优先）
# EMBEDDING_MODEL_PATH=/path/to/paraphrase-multilingual-MiniLM-L12-v2
