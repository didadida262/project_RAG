# Path to Gemma (or other) GGUF file — required for real answers
GGUF_MODEL_PATH=

# Optional: how many layers to offload to GPU (4060 8GB: try 20–35 with Q4)
N_GPU_LAYERS=0

# Context window budget for retrieved text (chars) before LLM
MAX_CONTEXT_CHARS=6000

# Generation
MAX_NEW_TOKENS=512
N_CTX=4096

# Retrieval
RAG_TOP_K=5

# --- 向量嵌入（首次会从网络拉取；国内直连 huggingface.co 超时可启用镜像或本地模型）---
# 镜像示例（不保证第三方长期可用；需要时取消下一行注释）
# HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DOWNLOAD_TIMEOUT=300

# 默认 Hub 模型名（未设置 EMBEDDING_MODEL_PATH 时才会联网下载）
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
#
# 提前下载到本机后填写绝对路径，可避免运行时访问 Hugging Face，例如：
#   huggingface-cli download sentence-transformers/all-MiniLM-L6-v2 --local-dir /path/to/all-MiniLM-L6-v2
# EMBEDDING_MODEL_PATH=/path/to/all-MiniLM-L6-v2
