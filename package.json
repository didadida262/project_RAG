{
  "name": "private-rag",
  "private": true,
  "version": "1.0.0",
  "description": "Private RAG — Electron + React",
  "type": "module",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:web\" \"wait-on -t 120000 http://127.0.0.1:5173 && electron .\"",
    "dev:web": "vite --config src/renderer/vite.config.ts",
    "build": "tsc -b src/renderer/tsconfig.json && vite build --config src/renderer/vite.config.ts",
    "preview": "vite preview --config src/renderer/vite.config.ts",
    "lint": "eslint \"src/renderer/**/*.{ts,tsx}\"",
    "electron:dev": "npm run dev",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "axios": "^1.14.0",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.private-rag.desktop",
    "productName": "Private RAG",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*.cjs",
      "src/preload/**/*.cjs",
      "src/renderer/dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "zip"],
      "category": "Office"
    }
  }
}
